<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PageCraft Studio — Agence Landing Pages Premium</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Syne:wght@400;500;600;700;800&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
:root {
  --ink: #0A0A0F;
  --ink-2: #12121A;
  --ink-3: #1C1C28;
  --cream: #F5F0E8;
  --cream-2: #EDE8DE;
  --gold: #C8A96E;
  --gold-2: #E8C98A;
  --electric: #4FFFB0;
  --electric-2: #00E87A;
  --rose: #FF6B8A;
  --white: #FAFAF8;
  --muted: #6B6B7A;
  --border: rgba(200,169,110,0.15);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: 'Syne', sans-serif;
  background: var(--ink);
  color: var(--cream);
  overflow-x: hidden;
  cursor: none;
}

/* ── CUSTOM CURSOR ── */
.cur { position: fixed; width: 12px; height: 12px; background: var(--electric); border-radius: 50%; pointer-events: none; z-index: 9999; transform: translate(-50%,-50%); transition: transform 0.1s; mix-blend-mode: exclusion; }
.cur-ring { position: fixed; width: 40px; height: 40px; border: 1px solid rgba(79,255,176,0.4); border-radius: 50%; pointer-events: none; z-index: 9998; transform: translate(-50%,-50%); transition: all 0.15s ease; }

/* ── TOPBAR ── */
.topbar {
  background: var(--electric);
  color: var(--ink);
  text-align: center;
  padding: 10px 20px;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  position: relative;
  z-index: 100;
}
.topbar span { background: var(--ink); color: var(--electric); padding: 2px 8px; border-radius: 4px; margin: 0 6px; }

/* ── NAV ── */
nav {
  position: fixed;
  top: 32px; left: 0; right: 0;
  z-index: 90;
  padding: 0 60px;
  height: 70px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: all 0.4s;
}
nav.scrolled {
  top: 0;
  background: rgba(10,10,15,0.95);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
  height: 64px;
}
.nav-logo {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.8rem;
  color: var(--cream);
  letter-spacing: 0.1em;
  text-decoration: none;
}
.nav-logo em { color: var(--electric); font-style: normal; }
.nav-links { display: flex; gap: 36px; list-style: none; }
.nav-links a { font-size: 0.78rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); text-decoration: none; transition: color 0.2s; }
.nav-links a:hover { color: var(--cream); }
.nav-cta {
  background: transparent;
  border: 1px solid var(--electric);
  color: var(--electric);
  border-radius: 6px;
  padding: 10px 24px;
  font-family: 'Syne', sans-serif;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.25s;
}
.nav-cta:hover { background: var(--electric); color: var(--ink); }

/* ── HERO ── */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  overflow: hidden;
  padding: 140px 60px 80px;
}

/* Background SVG artwork */
.hero-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
  overflow: hidden;
}

/* Animated grid */
.hero-bg-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(79,255,176,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(79,255,176,0.04) 1px, transparent 1px);
  background-size: 60px 60px;
  animation: grid-shift 20s linear infinite;
}
@keyframes grid-shift {
  0% { transform: translateY(0); }
  100% { transform: translateY(60px); }
}

/* Big decorative number */
.hero-bg-number {
  position: absolute;
  right: -2%;
  top: 50%;
  transform: translateY(-50%);
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(300px, 40vw, 500px);
  color: rgba(255,255,255,0.02);
  line-height: 1;
  pointer-events: none;
  user-select: none;
  letter-spacing: -0.05em;
}

/* Glow orbs */
.orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(100px);
  pointer-events: none;
  animation: orb-pulse 6s ease-in-out infinite;
}
.orb-1 { width: 500px; height: 500px; background: rgba(79,255,176,0.07); top: -100px; right: 10%; }
.orb-2 { width: 400px; height: 400px; background: rgba(255,107,138,0.05); bottom: -50px; left: 5%; animation-delay: -3s; }
.orb-3 { width: 300px; height: 300px; background: rgba(200,169,110,0.06); top: 30%; left: 40%; animation-delay: -1.5s; }
@keyframes orb-pulse { 0%,100% { opacity: 0.7; transform: scale(1); } 50% { opacity: 1; transform: scale(1.08); } }

/* Diagonal accent line */
.hero-diagonal {
  position: absolute;
  top: 0; right: 35%;
  width: 1px;
  height: 100%;
  background: linear-gradient(180deg, transparent, rgba(79,255,176,0.2), transparent);
  transform: rotate(15deg) translateX(100px);
}

.hero-inner {
  position: relative;
  z-index: 2;
  max-width: 1300px;
  width: 100%;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 80px;
  align-items: center;
}

/* Hero left */
.hero-tag {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 8px 16px;
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 32px;
  animation: fadeUp 0.7s ease both;
}
.hero-tag::before {
  content: '';
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--electric);
  animation: blink 2s ease-in-out infinite;
}

.hero-h1 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(4rem, 7vw, 8rem);
  line-height: 0.92;
  letter-spacing: 0.03em;
  margin-bottom: 32px;
  animation: fadeUp 0.7s 0.1s ease both;
}
.hero-h1 .line-1 { display: block; color: var(--cream); }
.hero-h1 .line-2 { display: block; color: var(--electric); -webkit-text-stroke: 0px; }
.hero-h1 .line-3 {
  display: block;
  -webkit-text-stroke: 1px var(--cream);
  color: transparent;
  opacity: 0.6;
}

.hero-sub {
  font-size: 1rem;
  color: var(--muted);
  line-height: 1.7;
  max-width: 480px;
  margin-bottom: 44px;
  font-weight: 400;
  animation: fadeUp 0.7s 0.2s ease both;
}
.hero-sub strong { color: var(--cream); font-weight: 600; }

.hero-ctas {
  display: flex;
  gap: 16px;
  align-items: center;
  margin-bottom: 60px;
  animation: fadeUp 0.7s 0.3s ease both;
  flex-wrap: wrap;
}
.btn-hero-primary {
  background: var(--electric);
  color: var(--ink);
  border: none;
  border-radius: 6px;
  padding: 18px 40px;
  font-family: 'Syne', sans-serif;
  font-size: 0.9rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.25s;
  position: relative;
  overflow: hidden;
}
.btn-hero-primary::after {
  content: '';
  position: absolute;
  top: -50%; left: -60%;
  width: 40%; height: 200%;
  background: rgba(255,255,255,0.3);
  transform: skewX(-20deg);
  transition: left 0.5s;
}
.btn-hero-primary:hover { background: var(--electric-2); transform: translateY(-2px); box-shadow: 0 12px 32px rgba(79,255,176,0.35); }
.btn-hero-primary:hover::after { left: 140%; }

.btn-hero-secondary {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--cream);
  letter-spacing: 0.06em;
  cursor: pointer;
  background: none;
  border: none;
  transition: gap 0.2s;
  text-decoration: none;
}
.btn-hero-secondary:hover { gap: 16px; }
.btn-hero-secondary .arrow {
  width: 36px; height: 36px;
  border: 1px solid var(--border);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1rem;
  transition: border-color 0.2s;
}
.btn-hero-secondary:hover .arrow { border-color: var(--electric); color: var(--electric); }

.hero-stats {
  display: flex;
  gap: 0;
  animation: fadeUp 0.7s 0.4s ease both;
  border-top: 1px solid var(--border);
  padding-top: 32px;
}
.hstat { flex: 1; }
.hstat+.hstat { border-left: 1px solid var(--border); padding-left: 28px; }
.hstat-num {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 2.8rem;
  color: var(--cream);
  line-height: 1;
  letter-spacing: 0.03em;
}
.hstat-num em { color: var(--electric); font-style: normal; }
.hstat-label { font-size: 0.7rem; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin-top: 4px; }

/* Hero right — mockup card */
.hero-mockup {
  position: relative;
  animation: fadeUp 0.7s 0.15s ease both;
}
.mockup-card {
  background: var(--ink-3);
  border: 1px solid var(--border);
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 60px 120px rgba(0,0,0,0.6), 0 0 0 1px rgba(79,255,176,0.05);
  position: relative;
}
.mockup-bar {
  background: var(--ink-2);
  padding: 12px 16px;
  display: flex;
  align-items: center;
  gap: 8px;
  border-bottom: 1px solid var(--border);
}
.mockup-dot { width: 10px; height: 10px; border-radius: 50%; }
.mockup-dot.r { background: #FF5F57; }
.mockup-dot.y { background: #FFBD2E; }
.mockup-dot.g { background: #28C840; }
.mockup-url {
  flex: 1;
  background: rgba(255,255,255,0.04);
  border-radius: 4px;
  padding: 5px 12px;
  font-size: 0.68rem;
  color: var(--muted);
  margin: 0 8px;
  letter-spacing: 0.04em;
}
.mockup-body {
  padding: 0;
  position: relative;
}
.mockup-hero-section {
  background: linear-gradient(135deg, #0A0A0F 0%, #1C1C28 50%, #0F1F15 100%);
  padding: 32px 28px;
  position: relative;
  overflow: hidden;
}
.mockup-hero-section::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(79,255,176,0.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(79,255,176,0.05) 1px, transparent 1px);
  background-size: 20px 20px;
}
.mockup-badge {
  display: inline-block;
  background: rgba(79,255,176,0.1);
  border: 1px solid rgba(79,255,176,0.2);
  color: var(--electric);
  font-size: 0.55rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 4px 10px;
  border-radius: 3px;
  margin-bottom: 12px;
  position: relative;
  z-index: 1;
}
.mockup-h {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 2.2rem;
  color: var(--cream);
  line-height: 1;
  margin-bottom: 10px;
  position: relative;
  z-index: 1;
  letter-spacing: 0.03em;
}
.mockup-h em { color: var(--electric); font-style: normal; }
.mockup-sub {
  font-size: 0.7rem;
  color: var(--muted);
  line-height: 1.5;
  margin-bottom: 18px;
  position: relative;
  z-index: 1;
  max-width: 240px;
}
.mockup-cta {
  background: var(--electric);
  color: var(--ink);
  border: none;
  border-radius: 5px;
  padding: 10px 20px;
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  cursor: default;
  position: relative;
  z-index: 1;
  display: inline-block;
}
.mockup-orb {
  position: absolute;
  width: 200px; height: 200px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(79,255,176,0.12) 0%, transparent 70%);
  top: -50px; right: -30px;
  filter: blur(30px);
}
.mockup-stats-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  border-top: 1px solid var(--border);
}
.mockup-stat {
  padding: 14px 16px;
  text-align: center;
  border-right: 1px solid var(--border);
}
.mockup-stat:last-child { border-right: none; }
.mockup-stat-num {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.4rem;
  color: var(--electric);
  line-height: 1;
  letter-spacing: 0.03em;
}
.mockup-stat-label {
  font-size: 0.55rem;
  color: var(--muted);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-top: 2px;
}

/* Floating badges on mockup */
.float-badge {
  position: absolute;
  background: var(--ink-2);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 12px 16px;
  box-shadow: 0 20px 40px rgba(0,0,0,0.4);
  white-space: nowrap;
}
.float-badge-1 {
  top: -24px;
  right: -24px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.fb-icon { font-size: 1.2rem; }
.fb-text { font-size: 0.7rem; font-weight: 600; color: var(--cream); }
.fb-sub { font-size: 0.6rem; color: var(--muted); }

.float-badge-2 {
  bottom: -20px;
  left: -20px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.fb-score {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 2rem;
  color: var(--electric);
  line-height: 1;
}
.fb-score-label { font-size: 0.62rem; color: var(--muted); }

/* ── LOGOS ── */
.logos-section {
  padding: 48px 60px;
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  position: relative;
  z-index: 2;
}
.logos-label { text-align: center; font-size: 0.68rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); margin-bottom: 28px; }
.logos-row { display: flex; justify-content: center; align-items: center; gap: 56px; flex-wrap: wrap; }
.logo-name {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.2rem;
  color: rgba(255,255,255,0.12);
  letter-spacing: 0.1em;
  transition: color 0.3s;
  cursor: default;
}
.logo-name:hover { color: rgba(79,255,176,0.4); }

/* ── SERVICES ── */
.services {
  padding: 120px 60px;
  position: relative;
  z-index: 2;
  max-width: 1300px;
  margin: 0 auto;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 72px;
}
.section-tag {
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--electric);
  margin-bottom: 14px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.section-tag::before { content: '//'; color: var(--muted); }
.section-h2 {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(2.4rem, 4vw, 3.8rem);
  line-height: 1.1;
  color: var(--cream);
  max-width: 500px;
}
.section-h2 em { font-style: italic; color: var(--gold); }
.section-desc { font-size: 0.9rem; color: var(--muted); max-width: 260px; line-height: 1.6; text-align: right; }

.services-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
  border-radius: 16px;
  overflow: hidden;
}
.service-card {
  background: var(--ink-2);
  padding: 44px 40px;
  position: relative;
  transition: background 0.3s;
  cursor: default;
}
.service-card:hover { background: var(--ink-3); }
.service-card::after {
  content: '';
  position: absolute;
  bottom: 0; left: 40px; right: 40px;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--electric), transparent);
  opacity: 0;
  transition: opacity 0.3s;
}
.service-card:hover::after { opacity: 1; }
.service-num {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 3.5rem;
  color: rgba(255,255,255,0.04);
  line-height: 1;
  margin-bottom: 20px;
  letter-spacing: 0.05em;
}
.service-icon {
  font-size: 2rem;
  margin-bottom: 18px;
  display: block;
}
.service-title {
  font-family: 'DM Serif Display', serif;
  font-size: 1.4rem;
  color: var(--cream);
  margin-bottom: 12px;
  line-height: 1.2;
}
.service-desc { font-size: 0.84rem; color: var(--muted); line-height: 1.65; margin-bottom: 24px; }
.service-tags { display: flex; gap: 8px; flex-wrap: wrap; }
.stag {
  font-size: 0.62rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  background: rgba(79,255,176,0.06);
  border: 1px solid rgba(79,255,176,0.12);
  color: var(--electric);
  padding: 4px 10px;
  border-radius: 3px;
}

/* ── PROCESS ── */
.process {
  padding: 120px 60px;
  background: var(--ink-2);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  position: relative;
  overflow: hidden;
}
.process::before {
  content: 'PROCESS';
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(100px, 20vw, 200px);
  color: rgba(255,255,255,0.015);
  white-space: nowrap;
  pointer-events: none;
  letter-spacing: 0.1em;
}
.process-inner { max-width: 1300px; margin: 0 auto; }
.process-steps {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 0;
  margin-top: 72px;
  position: relative;
}
.process-steps::before {
  content: '';
  position: absolute;
  top: 36px; left: 10%; width: 80%;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--border), rgba(79,255,176,0.3), var(--border), transparent);
}
.pstep { text-align: center; padding: 0 16px; position: relative; }
.pstep-num {
  width: 72px; height: 72px;
  border-radius: 50%;
  border: 1px solid var(--border);
  background: var(--ink);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24px;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.6rem;
  color: var(--gold);
  position: relative;
  z-index: 1;
  transition: all 0.3s;
  letter-spacing: 0.05em;
}
.pstep:hover .pstep-num {
  border-color: var(--electric);
  color: var(--electric);
  box-shadow: 0 0 32px rgba(79,255,176,0.2);
}
.pstep-title {
  font-family: 'DM Serif Display', serif;
  font-size: 1rem;
  color: var(--cream);
  margin-bottom: 8px;
}
.pstep-desc { font-size: 0.76rem; color: var(--muted); line-height: 1.55; }

/* ── PORTFOLIO ── */
.portfolio {
  padding: 120px 60px;
  max-width: 1300px;
  margin: 0 auto;
  position: relative;
  z-index: 2;
}
.portfolio-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  margin-top: 72px;
}
.portfolio-card {
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid var(--border);
  position: relative;
  transition: transform 0.3s, border-color 0.3s;
  cursor: pointer;
}
.portfolio-card:hover { transform: translateY(-6px); border-color: rgba(79,255,176,0.25); }
.portfolio-card-bg {
  height: 200px;
  position: relative;
  overflow: hidden;
}
.pc-bg-1 { background: linear-gradient(135deg, #0A0A0F, #1a1a2e, rgba(79,255,176,0.08)); }
.pc-bg-2 { background: linear-gradient(135deg, #0A0A0F, #2e1a1a, rgba(255,107,138,0.08)); }
.pc-bg-3 { background: linear-gradient(135deg, #0A0A0F, #1a2e1a, rgba(200,169,110,0.1)); }
.portfolio-card-bg::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size: 24px 24px;
}
.pc-inner {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 8px;
}
.pc-icon { font-size: 3rem; filter: drop-shadow(0 0 20px rgba(79,255,176,0.3)); }
.pc-type {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1rem;
  color: rgba(255,255,255,0.4);
  letter-spacing: 0.1em;
}
.portfolio-card-info {
  background: var(--ink-2);
  padding: 20px 24px;
